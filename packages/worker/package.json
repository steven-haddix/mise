{
  "name": "@mise/worker",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt src",
    "fmt:check": "oxfmt --check src"
  },
  "dependencies": {
    "@mise/api": "workspace:*",
    "@mise/shared": "workspace:*",
    "drizzle-orm": "latest",
    "hono": "latest",
    "postgres": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
